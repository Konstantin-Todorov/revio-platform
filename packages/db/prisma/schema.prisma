// Revio persistence schema. Every tenant-owned row carries tenantId (RLS added via raw-SQL migration).
// Domain math lives in @revio/core; this schema only stores and retrieves.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Tenancy ---------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Entitlements: which products this hotel account bought ("sold separately").
  hasChannelManager Boolean @default(true)
  hasReservation    Boolean @default(false)
  hasPms            Boolean @default(false)
  // Commercial profile, set by the operator. plan ≈ room-count tier / package; status gates access.
  plan      String   @default("starter") // starter | growth | scale
  status    String   @default("active")  // active | suspended
  createdAt DateTime @default(now())

  properties Property[]
  users      User[]
}

model User {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  email        String  @unique
  role         String // owner | admin | revenue_manager | distribution_manager | read_only
  passwordHash String? // null until the invited Owner sets their password

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Operator staff (us). Cross-tenant by design — NOT tied to any tenant.
model OperatorUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String   @default("super_admin") // super_admin | support
  passwordHash String
  createdAt    DateTime @default(now())
}

// Per-tenant connectivity credential (e.g. a Channex API key), AES-256-GCM encrypted at rest.
// Operator-managed; a hotel can NEVER read it (RLS policy = bypass-only). The CM reads it server-side
// at push/pull time via the system perimeter — the plaintext key is never sent to any client.
model ConnectivityCredential {
  id        String   @id @default(cuid())
  tenantId  String
  mode      String // channex_sandbox | channex_prod
  cipher    String // base64 iv.tag.ciphertext (AES-256-GCM)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, mode])
  @@index([tenantId])
}

// --- Property & sellable products -----------------------------------------

model Property {
  id              String @id @default(cuid())
  tenantId        String
  name            String
  timezone        String @default("Europe/Sofia")
  baseCurrency    String @default("EUR")
  defaultLanguage String @default("en")
  syncHorizonDays Int    @default(365)
  address         String?
  contactEmail    String?
  phone           String?
  checkInTime     String @default("14:00")
  checkOutTime    String @default("12:00")
  status          String @default("active")

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTypes           RoomType[]
  ratePlans           RatePlan[]
  channels            Channel[]
  cancellationPolicies CancellationPolicy[]
  mealPlans           MealPlan[]
  ratePrices          RatePrice[]
  dailyCells          DailyCell[]
  restrictionRules    RestrictionRule[]
  reservations        Reservation[]
  syncEvents          SyncEvent[]
  errorItems          ErrorItem[]
  auditEntries        AuditEntry[]
  inventoryPeriods    RoomInventoryPeriod[]
  holds               Hold[]
  guests              Guest[]
  bookingSources      BookingSource[]
  taxesFees           TaxFee[]
  pickupSnapshots     PickupSnapshot[]
  defaults            PropertyDefaults?
  units               Unit[]
  hkTasks             HousekeepingTask[]

  @@index([tenantId])
}

model RoomType {
  id             String  @id @default(cuid())
  tenantId       String
  propertyId     String
  name           String
  code           String
  // room | bed | apartment. Hotels/apartments sell whole units; hostels sell beds, so a "bed"
  // unitKind means totalRooms counts beds and availability is controlled per bed.
  unitKind       String  @default("room")
  // Physical room/bed count — a CAP & safety-net only. Rooms-to-sell is managed per date
  // (DailyCell.inventory); exceeding totalRooms warns but does not block.
  totalRooms     Int
  maxGuests      Int
  description    String?
  active         Boolean @default(true)
  sortOrder      Int     @default(0)

  property      Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlanLinks RatePlanRoomType[]
  mappings      ProductMapping[]
  channelMappings ChannelRoomTypeMapping[]
  ratePrices    RatePrice[]
  dailyCells    DailyCell[]
  resLines      ReservationLine[]
  inventoryPeriods RoomInventoryPeriod[]
  holds            Hold[]
  pickupSnapshots  PickupSnapshot[]
  units            Unit[]

  @@index([propertyId])
}

model CancellationPolicy {
  id          String @id @default(cuid())
  tenantId    String
  propertyId  String
  name        String
  code        String
  description String?

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlans RatePlan[]

  @@index([propertyId])
}

model MealPlan {
  id         String @id @default(cuid())
  tenantId   String
  propertyId String
  name       String
  code       String

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlans RatePlan[]

  @@index([propertyId])
}

model RatePlan {
  id         String @id @default(cuid())
  tenantId   String
  propertyId String
  name       String
  code       String
  // Arbitrary labels the hotel uses for orientation, e.g. ["breakfast","non-refundable","corporate"].
  tags       String[]
  priceLogic String @default("manual") // manual | derived

  // Derived-rate config (when priceLogic = derived) — consumed by @revio/core deriveRate().
  parentRatePlanId String?
  derivedType      String? // percent | fixed
  derivedDirection String? // increase | decrease
  derivedValue     Int? // percent (0-100) or minor units
  derivedRounding  String? // none | nearest_minor_1 | nearest_minor_50 | end_99
  derivedFloorMinor   Int?
  derivedCeilingMinor Int?

  cancellationPolicyId String?
  mealPlanId           String?

  // Default restriction baseline (fallback when nothing more specific applies).
  defStopSell          Boolean @default(false)
  defMinLos            Int?
  defMaxLos            Int?
  defCta               Boolean @default(false)
  defCtd               Boolean @default(false)
  defAdvancePurchaseMin Int?
  defAdvancePurchaseMax Int?

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  parent             RatePlan?           @relation("Derivation", fields: [parentRatePlanId], references: [id])
  children           RatePlan[]          @relation("Derivation")
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  mealPlan           MealPlan?           @relation(fields: [mealPlanId], references: [id])
  roomTypeLinks      RatePlanRoomType[]
  mappings           ProductMapping[]
  channelMappings    ChannelRatePlanMapping[]
  ratePrices         RatePrice[]
  resLines           ReservationLine[]
  occupancyAdjustments OccupancyAdjustment[]

  @@index([propertyId])
}

// Occupancy-based pricing: a price delta applied for a given guest count, relative to the rate plan's
// base (max-occupancy) price. Implements "price for 2 guests − €10 = price for 1 guest".
model OccupancyAdjustment {
  id             String @id @default(cuid())
  tenantId       String
  ratePlanId     String
  occupancy      Int    // number of guests this price applies to
  adjustmentType String // percent | fixed
  direction      String // increase | decrease
  value          Int    // percent (0-100) or minor units
  rounding       String @default("none")

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, occupancy])
  @@index([ratePlanId])
}

// Room Type x Rate Plan = a sellable Product.
model RatePlanRoomType {
  ratePlanId String
  roomTypeId String

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@id([ratePlanId, roomTypeId])
  @@index([roomTypeId])
}

// --- Channels & mapping ----------------------------------------------------

model Channel {
  id                  String   @id @default(cuid())
  tenantId            String
  propertyId          String
  code                String // booking | expedia | trip | agoda
  name                String
  status              String   @default("connected") // connected|not_connected|pending|error|disabled
  // Which adapter this channel pushes through (@revio/connectivity). Demo channels stay on "mock"; a
  // channel set to channex_* talks to the real Channex API. externalPropertyId is the Channex Property UUID.
  connectivityMode    String   @default("mock") // mock | channex_sandbox | channex_prod
  externalPropertyId  String?
  currency            String   @default("EUR")
  commissionPct       Float    @default(15)
  conversionType      String   @default("none") // none|manual|auto|channel_override
  markupPct           Float    @default(0)
  rounding            String   @default("none")
  supportedRestrictions String[]
  lastSyncAt          DateTime?
  errorCount          Int      @default(0)
  pendingCount        Int      @default(0)
  // CRS reporting category this channel's bookings fall under (see BookingSource).
  bookingSourceId     String?

  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookingSource BookingSource? @relation(fields: [bookingSourceId], references: [id])
  mappings ProductMapping[]
  roomTypeMappings ChannelRoomTypeMapping[]
  ratePlanMappings ChannelRatePlanMapping[]
  reservations Reservation[]
  syncEvents SyncEvent[]
  errorItems ErrorItem[]

  @@index([propertyId])
}

model ProductMapping {
  id             String @id @default(cuid())
  tenantId       String
  channelId      String
  roomTypeId     String
  ratePlanId     String
  externalRoomId String?
  externalRateId String?
  status         String @default("complete") // complete|incomplete|missing_room|missing_rate|channel_error|disabled|pending_confirmation

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([channelId, roomTypeId, ratePlanId])
  @@index([channelId])
}

// Two-stream mapping (V2): a channel maps each Room Type and each Rate Plan to the channel's own id,
// independently — mirrors Channex (availability keyed on room type, rates/restrictions on rate plan).
// Replaces the per-product externalRoomId/externalRateId redundancy in ProductMapping.
model ChannelRoomTypeMapping {
  id             String  @id @default(cuid())
  tenantId       String
  channelId      String
  roomTypeId     String
  externalRoomId String?
  status         String  @default("incomplete") // complete | incomplete

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([channelId, roomTypeId])
  @@index([channelId])
}

model ChannelRatePlanMapping {
  id             String  @id @default(cuid())
  tenantId       String
  channelId      String
  ratePlanId     String
  externalRateId String?
  status         String  @default("incomplete") // complete | incomplete

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([channelId, ratePlanId])
  @@index([channelId])
}

// --- Calendar data ---------------------------------------------------------

// Daily price for a (room type, rate plan). Only stored for manual rates; derived computed on read.
model RatePrice {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  roomTypeId String
  ratePlanId String
  date       DateTime @db.Date
  priceMinor Int

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, ratePlanId, date])
  @@index([propertyId, date])
}

// Per-(room type, date) inventory allotment + restriction flags shown in the Calendar grid.
model DailyCell {
  id                  String   @id @default(cuid())
  tenantId            String
  propertyId          String
  roomTypeId          String
  date                DateTime @db.Date
  // Date-level "rooms to sell" allotment. Null ⇒ default to the room type's totalRooms.
  // Bookable = inventory − rooms sold (sold is derived from confirmed reservations, never stored here).
  inventory           Int?
  minLos              Int?
  maxLos              Int?
  cta                 Boolean  @default(false)
  ctd                 Boolean  @default(false)
  stopSell            Boolean  @default(false)
  advancePurchaseMin  Int?
  advancePurchaseMax  Int?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@index([propertyId, date])
}

// --- Restrictions ----------------------------------------------------------

model RestrictionRule {
  id           String   @id @default(cuid())
  tenantId     String
  propertyId   String
  name         String
  type         String // stop_sell|min_los|max_los|cta|ctd|advance_purchase_min|advance_purchase_max|channel_allocation
  roomTypeId   String?
  ratePlanId   String?
  channelCodes String[]
  // CRS: scope by booking source category (docs/CRS-REFERENCE.md — e.g. closed to Travel Agent,
  // open to Direct). Empty = applies to every source. Categories match BookingSource.category.
  sourceCategories String[] @default([])
  dateFrom     DateTime @db.Date
  dateTo       DateTime @db.Date
  daysOfWeek   String   @default("all")
  valueInt     Int?
  valueBool    Boolean?
  priority     Int      @default(0)
  active       Boolean  @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// --- Reservations ----------------------------------------------------------

model Reservation {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  // Null for staff-entered bookings (Call Center / Direct / Corporate) — those never touch a CM.
  channelId  String?
  externalId String?
  guestName  String
  // CM statuses: confirmed|modified|cancelled|failed_import|overbooked ("modified" = confirmed that
  // was modified — a flag-as-status, still counts as sold). CRS lifecycle adds:
  // draft|hold|expired|failed|no_show|archived (docs/CRS-REFERENCE.md "Reservation lifecycle").
  status     String   @default("confirmed")
  // ORIGINAL booking values (what the guest was actually charged), captured at booking time.
  totalMinor Int
  currency   String   @default("EUR")
  // CRS-compatible currency snapshot: the same amount converted to the property's base currency, plus
  // the FX rate + timestamp used. Stored at booking time so historical revenue reports stay reproducible
  // when exchange rates move (see docs/CRS-REFERENCE.md "Currency handling"). Null on legacy rows.
  propertyCurrency   String?
  propertyTotalMinor Int?
  fxRate             Float?
  fxAt               DateTime?
  importedAt DateTime @default(now())
  syncStatus String   @default("imported")
  // CRS fields (docs/CRS-REFERENCE.md). paymentGuarantee is a LABEL only — no card data in V1.
  guestId          String?
  bookingSourceId  String?
  paymentGuarantee String? // card_on_file | company_account | prepaid_ota | none
  notes            String?
  cancelledAt      DateTime?
  createdById      String? // staff user who entered a manual booking

  property Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel?          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  guest         Guest?         @relation(fields: [guestId], references: [id])
  bookingSource BookingSource? @relation(fields: [bookingSourceId], references: [id])
  lines    ReservationLine[]
  holds    Hold[]

  @@index([propertyId])
  @@index([channelId])
}

model ReservationLine {
  id            String   @id @default(cuid())
  reservationId String
  roomTypeId    String
  ratePlanId    String
  quantity      Int      @default(1)
  checkIn       DateTime @db.Date
  checkOut      DateTime @db.Date
  // CRS: the line's accommodation price (whole stay, minor units) + guests staying. Null on legacy rows.
  priceMinor    Int?
  guestsCount   Int?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomType    RoomType    @relation(fields: [roomTypeId], references: [id])
  ratePlan    RatePlan    @relation(fields: [ratePlanId], references: [id])

  @@index([reservationId])
}

// --- CRS: inventory periods, holds, guests, sources, taxes, snapshots ------
// (docs/CRS-REFERENCE.md — all tenant-owned, RLS tenant_isolation added in the migration.)

// Date-ranged unavailability for a room type: out-of-order (maintenance) or closure (seasonal).
// Waterfall level 1: available = physical − OOO − closed. Separate from the permanent total.
model RoomInventoryPeriod {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  roomTypeId String
  kind       String // out_of_order | closure
  dateFrom   DateTime @db.Date
  dateTo     DateTime @db.Date // inclusive
  rooms      Int      @default(1) // units affected (a closure usually = all units)
  note       String?
  // Set when this OOO period was created by a specific PMS Unit going out_of_order — the one
  // cross-product write (docs/PMS-REFERENCE.md): un-OOO deletes the period, restoring the waterfall.
  unitId     String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([roomTypeId, dateFrom])
  @@index([propertyId])
  @@index([unitId])
}

// Temporary inventory lock, placed the INSTANT a room is selected (before the form saves).
// Waterfall level 2: remaining = available − holds − confirmed. Expired holds are released by a job.
model Hold {
  id            String   @id @default(cuid())
  tenantId      String
  propertyId    String
  roomTypeId    String
  reservationId String?
  quantity      Int      @default(1)
  checkIn       DateTime @db.Date
  checkOut      DateTime @db.Date
  status        String   @default("active") // active | converted | released | expired
  expiresAt     DateTime
  createdById   String?
  createdAt     DateTime @default(now())

  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType    RoomType     @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([propertyId, status])
  @@index([roomTypeId, checkIn])
}

// Contact + booking history ONLY — hard scope line, not a CRM (no preferences/consent/loyalty).
model Guest {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  company         String?
  specialRequests String? // free text
  createdAt       DateTime @default(now())

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([propertyId, lastName])
}

// Reporting category each channel/booking belongs to (Direct, OTA, GDS, Call Center, Corporate,
// Travel Agent). Channels map to a source; staff-entered bookings are tagged at creation.
model BookingSource {
  id         String  @id @default(cuid())
  tenantId   String
  propertyId String
  name       String
  category   String // direct | ota | gds | call_center | corporate | travel_agent
  active     Boolean @default(true)

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channels     Channel[]
  reservations Reservation[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

// Percent taxes use pct; fixed use amountMinor (money = integer minor units, never floats).
// inclusion drives Room Revenue: "included" taxes are inside the displayed rate.
model TaxFee {
  id          String  @id @default(cuid())
  tenantId    String
  propertyId  String
  name        String
  type        String // percent | fixed
  pct         Float?
  amountMinor Int?
  basis       String // per_room | per_person | per_night | per_stay
  inclusion   String  @default("excluded") // included | excluded
  active      Boolean @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// Nightly record of rooms sold per future stay date. Pickup = sold NOW − sold at snapshot N days
// ago. Snapshots can never be backfilled — the job runs from Phase 1 day one.
model PickupSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  propertyId   String
  roomTypeId   String
  snapshotDate DateTime @db.Date // property-timezone date the snapshot was taken
  targetDate   DateTime @db.Date // the future stay date measured
  roomsSold    Int
  revenueMinor Int      @default(0)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([propertyId, roomTypeId, snapshotDate, targetDate])
  @@index([propertyId, targetDate])
}

// Property-level restriction fallback (priority level 4, below rate-plan defaults) + CRS settings.
model PropertyDefaults {
  id                    String  @id @default(cuid())
  tenantId              String
  propertyId            String  @unique
  defStopSell           Boolean @default(false)
  defMinLos             Int?
  defMaxLos             Int?
  defCta                Boolean @default(false)
  defCtd                Boolean @default(false)
  defAdvancePurchaseMin Int?
  defAdvancePurchaseMax Int?
  // Metric settings (docs/CRS-REFERENCE.md "Core metrics")
  countNoShowsAsSold Boolean @default(true)
  revenueDisplay     String  @default("gross") // gross | net
  pickupOffsetDays   Int     @default(7)
  holdTtlMinutes     Int     @default(30)
  // Action Center thresholds (docs/CRS-REFERENCE.md: every threshold a Setting, never hardcoded).
  lowAvailabilityThreshold Int @default(2)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// Roles = saved combinations of permission-group × access level (new roles are configuration,
// not code). Groups: reservations|rates|inventory|restrictions|users|reports|distribution|finance.
model PermissionRole {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  builtin  Boolean @default(false)

  access RoleAccess[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model RoleAccess {
  id       String @id @default(cuid())
  tenantId String
  roleId   String
  group    String
  level    String @default("none") // none | view | edit

  role PermissionRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, group])
}

// --- PMS: physical units + housekeeping (docs/PMS-REFERENCE.md) ------------
// The PMS is the first product that cares WHICH physical room/bed (to clean/assign/bill it). A Unit is
// an addressable sellable unit under a RoomType; it does NOT change the availability math — RoomType
// counts stay the source of truth for what's sellable. Marking a Unit out_of_order writes a
// RoomInventoryPeriod so the shared waterfall takes it off sale (the ONE cross-product write).
// All tenant-owned → tenant_isolation RLS added in the migration.
model Unit {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  roomTypeId String
  label      String   // room number / name (e.g. "101", "Sea View 2") or a bed label for hostels
  unitKind   String   @default("room") // room | bed (mirrors RoomType.unitKind; built rooms-first in V1)
  floor      String?  // floor or zone — groups the housekeeping board
  // Current housekeeping status (single value; changes logged to AuditEntry). Occupancy status is
  // DERIVED from room assignments (Phase 2), never stored here.
  hkStatus   String   @default("clean") // clean | dirty | inspected | out_of_order
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  property         Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType         RoomType              @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  hkTasks          HousekeepingTask[]
  inventoryPeriods RoomInventoryPeriod[]

  @@index([propertyId])
  @@index([roomTypeId, sortOrder])
}

// A housekeeping / turndown / inspection task, optionally against a specific Unit. Basic in V1.
model HousekeepingTask {
  id          String    @id @default(cuid())
  tenantId    String
  propertyId  String
  unitId      String?
  type        String    @default("clean") // clean | inspect | turndown
  status      String    @default("open")  // open | in_progress | done
  assignee    String?   // free-text staff name (or userId) — light in V1
  note        String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([propertyId, status])
}

// --- Monitoring: Sync / Error / Audit -------------------------------------

model SyncEvent {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  channelId  String?
  kind       String // push | pull
  status     String // pending | success | failed
  summary    String
  detail     String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel? @relation(fields: [channelId], references: [id])

  @@index([propertyId, createdAt])
}

model ErrorItem {
  id                String   @id @default(cuid())
  tenantId          String
  propertyId        String
  channelId         String?
  severity          String // info | warning | critical
  code              String
  message           String
  productLabel      String?
  dateAffected      DateTime? @db.Date
  recommendedAction String?
  resolved          Boolean  @default(false)
  createdAt         DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel? @relation(fields: [channelId], references: [id])

  @@index([propertyId, resolved])
}

model AuditEntry {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  userId     String?
  entity     String
  field      String?
  oldValue   String?
  newValue   String?
  source     String // manual | api | bulk | rule
  channelCode String?
  syncResult String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
}
