// Revio persistence schema. Every tenant-owned row carries tenantId (RLS added via raw-SQL migration).
// Domain math lives in @revio/core; this schema only stores and retrieves.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Tenancy ---------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Entitlements: which products this hotel account bought ("sold separately").
  hasChannelManager Boolean @default(true)
  hasReservation    Boolean @default(false)
  hasPms            Boolean @default(false)
  // Commercial profile, set by the operator. plan ≈ room-count tier / package; status gates access.
  plan      String   @default("starter") // starter | growth | scale
  status    String   @default("active")  // active | suspended
  createdAt DateTime @default(now())

  properties Property[]
  users      User[]
}

model User {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  email        String  @unique
  role         String // owner | admin | revenue_manager | distribution_manager | read_only
  passwordHash String? // null until the invited Owner sets their password

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Operator staff (us). Cross-tenant by design — NOT tied to any tenant.
model OperatorUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String   @default("super_admin") // super_admin | support
  passwordHash String
  createdAt    DateTime @default(now())
}

// --- Property & sellable products -----------------------------------------

model Property {
  id              String @id @default(cuid())
  tenantId        String
  name            String
  timezone        String @default("Europe/Sofia")
  baseCurrency    String @default("EUR")
  defaultLanguage String @default("en")
  syncHorizonDays Int    @default(365)
  address         String?
  contactEmail    String?
  phone           String?
  checkInTime     String @default("14:00")
  checkOutTime    String @default("12:00")
  status          String @default("active")

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTypes           RoomType[]
  ratePlans           RatePlan[]
  channels            Channel[]
  cancellationPolicies CancellationPolicy[]
  mealPlans           MealPlan[]
  ratePrices          RatePrice[]
  dailyCells          DailyCell[]
  restrictionRules    RestrictionRule[]
  reservations        Reservation[]
  syncEvents          SyncEvent[]
  errorItems          ErrorItem[]
  auditEntries        AuditEntry[]

  @@index([tenantId])
}

model RoomType {
  id             String  @id @default(cuid())
  tenantId       String
  propertyId     String
  name           String
  code           String
  // room | bed | apartment. Hotels/apartments sell whole units; hostels sell beds, so a "bed"
  // unitKind means totalRooms counts beds and availability is controlled per bed.
  unitKind       String  @default("room")
  // Physical room/bed count — a CAP & safety-net only. Rooms-to-sell is managed per date
  // (DailyCell.inventory); exceeding totalRooms warns but does not block.
  totalRooms     Int
  maxGuests      Int
  description    String?
  active         Boolean @default(true)
  sortOrder      Int     @default(0)

  property      Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlanLinks RatePlanRoomType[]
  mappings      ProductMapping[]
  channelMappings ChannelRoomTypeMapping[]
  ratePrices    RatePrice[]
  dailyCells    DailyCell[]
  resLines      ReservationLine[]

  @@index([propertyId])
}

model CancellationPolicy {
  id          String @id @default(cuid())
  tenantId    String
  propertyId  String
  name        String
  code        String
  description String?

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlans RatePlan[]

  @@index([propertyId])
}

model MealPlan {
  id         String @id @default(cuid())
  tenantId   String
  propertyId String
  name       String
  code       String

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ratePlans RatePlan[]

  @@index([propertyId])
}

model RatePlan {
  id         String @id @default(cuid())
  tenantId   String
  propertyId String
  name       String
  code       String
  // Arbitrary labels the hotel uses for orientation, e.g. ["breakfast","non-refundable","corporate"].
  tags       String[]
  priceLogic String @default("manual") // manual | derived

  // Derived-rate config (when priceLogic = derived) — consumed by @revio/core deriveRate().
  parentRatePlanId String?
  derivedType      String? // percent | fixed
  derivedDirection String? // increase | decrease
  derivedValue     Int? // percent (0-100) or minor units
  derivedRounding  String? // none | nearest_minor_1 | nearest_minor_50 | end_99
  derivedFloorMinor   Int?
  derivedCeilingMinor Int?

  cancellationPolicyId String?
  mealPlanId           String?

  // Default restriction baseline (fallback when nothing more specific applies).
  defStopSell          Boolean @default(false)
  defMinLos            Int?
  defMaxLos            Int?
  defCta               Boolean @default(false)
  defCtd               Boolean @default(false)
  defAdvancePurchaseMin Int?
  defAdvancePurchaseMax Int?

  active    Boolean @default(true)
  sortOrder Int     @default(0)

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  parent             RatePlan?           @relation("Derivation", fields: [parentRatePlanId], references: [id])
  children           RatePlan[]          @relation("Derivation")
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  mealPlan           MealPlan?           @relation(fields: [mealPlanId], references: [id])
  roomTypeLinks      RatePlanRoomType[]
  mappings           ProductMapping[]
  channelMappings    ChannelRatePlanMapping[]
  ratePrices         RatePrice[]
  resLines           ReservationLine[]
  occupancyAdjustments OccupancyAdjustment[]

  @@index([propertyId])
}

// Occupancy-based pricing: a price delta applied for a given guest count, relative to the rate plan's
// base (max-occupancy) price. Implements "price for 2 guests − €10 = price for 1 guest".
model OccupancyAdjustment {
  id             String @id @default(cuid())
  tenantId       String
  ratePlanId     String
  occupancy      Int    // number of guests this price applies to
  adjustmentType String // percent | fixed
  direction      String // increase | decrease
  value          Int    // percent (0-100) or minor units
  rounding       String @default("none")

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, occupancy])
  @@index([ratePlanId])
}

// Room Type x Rate Plan = a sellable Product.
model RatePlanRoomType {
  ratePlanId String
  roomTypeId String

  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@id([ratePlanId, roomTypeId])
  @@index([roomTypeId])
}

// --- Channels & mapping ----------------------------------------------------

model Channel {
  id                  String   @id @default(cuid())
  tenantId            String
  propertyId          String
  code                String // booking | expedia | trip | agoda
  name                String
  status              String   @default("connected") // connected|not_connected|pending|error|disabled
  externalPropertyId  String?
  currency            String   @default("EUR")
  commissionPct       Float    @default(15)
  conversionType      String   @default("none") // none|manual|auto|channel_override
  markupPct           Float    @default(0)
  rounding            String   @default("none")
  supportedRestrictions String[]
  lastSyncAt          DateTime?
  errorCount          Int      @default(0)
  pendingCount        Int      @default(0)

  property Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  mappings ProductMapping[]
  roomTypeMappings ChannelRoomTypeMapping[]
  ratePlanMappings ChannelRatePlanMapping[]
  reservations Reservation[]
  syncEvents SyncEvent[]
  errorItems ErrorItem[]

  @@index([propertyId])
}

model ProductMapping {
  id             String @id @default(cuid())
  tenantId       String
  channelId      String
  roomTypeId     String
  ratePlanId     String
  externalRoomId String?
  externalRateId String?
  status         String @default("complete") // complete|incomplete|missing_room|missing_rate|channel_error|disabled|pending_confirmation

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([channelId, roomTypeId, ratePlanId])
  @@index([channelId])
}

// Two-stream mapping (V2): a channel maps each Room Type and each Rate Plan to the channel's own id,
// independently — mirrors Channex (availability keyed on room type, rates/restrictions on rate plan).
// Replaces the per-product externalRoomId/externalRateId redundancy in ProductMapping.
model ChannelRoomTypeMapping {
  id             String  @id @default(cuid())
  tenantId       String
  channelId      String
  roomTypeId     String
  externalRoomId String?
  status         String  @default("incomplete") // complete | incomplete

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([channelId, roomTypeId])
  @@index([channelId])
}

model ChannelRatePlanMapping {
  id             String  @id @default(cuid())
  tenantId       String
  channelId      String
  ratePlanId     String
  externalRateId String?
  status         String  @default("incomplete") // complete | incomplete

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([channelId, ratePlanId])
  @@index([channelId])
}

// --- Calendar data ---------------------------------------------------------

// Daily price for a (room type, rate plan). Only stored for manual rates; derived computed on read.
model RatePrice {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  roomTypeId String
  ratePlanId String
  date       DateTime @db.Date
  priceMinor Int

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  ratePlan RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, ratePlanId, date])
  @@index([propertyId, date])
}

// Per-(room type, date) inventory allotment + restriction flags shown in the Calendar grid.
model DailyCell {
  id                  String   @id @default(cuid())
  tenantId            String
  propertyId          String
  roomTypeId          String
  date                DateTime @db.Date
  // Date-level "rooms to sell" allotment. Null ⇒ default to the room type's totalRooms.
  // Bookable = inventory − rooms sold (sold is derived from confirmed reservations, never stored here).
  inventory           Int?
  minLos              Int?
  maxLos              Int?
  cta                 Boolean  @default(false)
  ctd                 Boolean  @default(false)
  stopSell            Boolean  @default(false)
  advancePurchaseMin  Int?
  advancePurchaseMax  Int?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@index([propertyId, date])
}

// --- Restrictions ----------------------------------------------------------

model RestrictionRule {
  id           String   @id @default(cuid())
  tenantId     String
  propertyId   String
  name         String
  type         String // stop_sell|min_los|max_los|cta|ctd|advance_purchase_min|advance_purchase_max|channel_allocation
  roomTypeId   String?
  ratePlanId   String?
  channelCodes String[]
  dateFrom     DateTime @db.Date
  dateTo       DateTime @db.Date
  daysOfWeek   String   @default("all")
  valueInt     Int?
  valueBool    Boolean?
  priority     Int      @default(0)
  active       Boolean  @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// --- Reservations ----------------------------------------------------------

model Reservation {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  channelId  String
  externalId String
  guestName  String
  status     String   @default("confirmed") // confirmed|modified|cancelled|failed_import|overbooked
  // ORIGINAL booking values (what the guest was actually charged), captured at booking time.
  totalMinor Int
  currency   String   @default("EUR")
  // CRS-compatible currency snapshot: the same amount converted to the property's base currency, plus
  // the FX rate + timestamp used. Stored at booking time so historical revenue reports stay reproducible
  // when exchange rates move (see docs/CRS-REFERENCE.md "Currency handling"). Null on legacy rows.
  propertyCurrency   String?
  propertyTotalMinor Int?
  fxRate             Float?
  fxAt               DateTime?
  importedAt DateTime @default(now())
  syncStatus String   @default("imported")

  property Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lines    ReservationLine[]

  @@index([propertyId])
  @@index([channelId])
}

model ReservationLine {
  id            String   @id @default(cuid())
  reservationId String
  roomTypeId    String
  ratePlanId    String
  quantity      Int      @default(1)
  checkIn       DateTime @db.Date
  checkOut      DateTime @db.Date

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomType    RoomType    @relation(fields: [roomTypeId], references: [id])
  ratePlan    RatePlan    @relation(fields: [ratePlanId], references: [id])

  @@index([reservationId])
}

// --- Monitoring: Sync / Error / Audit -------------------------------------

model SyncEvent {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  channelId  String?
  kind       String // push | pull
  status     String // pending | success | failed
  summary    String
  detail     String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel? @relation(fields: [channelId], references: [id])

  @@index([propertyId, createdAt])
}

model ErrorItem {
  id                String   @id @default(cuid())
  tenantId          String
  propertyId        String
  channelId         String?
  severity          String // info | warning | critical
  code              String
  message           String
  productLabel      String?
  dateAffected      DateTime? @db.Date
  recommendedAction String?
  resolved          Boolean  @default(false)
  createdAt         DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel  Channel? @relation(fields: [channelId], references: [id])

  @@index([propertyId, resolved])
}

model AuditEntry {
  id         String   @id @default(cuid())
  tenantId   String
  propertyId String
  userId     String?
  entity     String
  field      String?
  oldValue   String?
  newValue   String?
  source     String // manual | api | bulk | rule
  channelCode String?
  syncResult String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
}
